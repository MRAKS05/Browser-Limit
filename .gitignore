# Gradle files
.gradle/
/build
/*/build

# Build outputs (APKs, AABs)
*.apk
*.aab
*.so

# IDE files (machine-specific workspace)
.idea/workspace.xml
.idea/tasks.xml
.idea/navEditor.xml
.idea/assetWizardSettings.xml
.idea/caches/
.idea/*.iml
*.iml

# IDE (but keep project structure for contributors)
.vscode/
.vs/

# Local machine configuration
local.properties

# SDK and toolchain directories
/android-sdk/

# Security sensitive files
*.keystore
*.jks
debug.keystore
debug.keystore.base64

# OS-specific files
.DS_Store
Thumbs.db
.DS_Store?
._*

# Log files
*.log

# Native builds
.externalNativeBuild/
.cxx/

# Environment-specific
.env
.env.local

# AI memory and local analysis cache
.ai_memory/

# Local release signing keystore; do not commit secret key material
/release.keystore

# Keep built APKs for distribution (explicitly allow this folder)
!apks/
!apks/*.apk

# Keep build output APKs in our staging folder
!.build_output/
!.build_output/*.apk

# Allow our debug APK output folder
!.build_output/
!.build_output/*.apk
